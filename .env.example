ALFRED_ENV=dev
PORT=3000

OPENAI_API_KEY=

SEARXNG_BASE_URL=http://127.0.0.1:8888
SEARXNG_SEARCH_PATH=/search
SEARXNG_HEALTH_PATH=/search?q=ping&format=json
SEARXNG_START_CMD=./manage webapp.run
SEARXNG_START_TIMEOUT_MS=15000
SEARXNG_RETRY_INTERVAL_MS=1000
SEARXNG_HEALTH_RETRIES=2
SEARXNG_HEALTH_RETRY_DELAY_MS=250
SEARXNG_HEALTH_GRACE_MS=15000

BRAVE_SEARCH_API_KEY=

ALFRED_SEARCH_MAX_RESULTS=15
ALFRED_FAST_SCRAPE_COUNT=10
ALFRED_ENABLE_PLAYWRIGHT=true
ALFRED_RUN_MAX_STEPS=6
ALFRED_WORKSPACE_DIR=./workspace/alfred
ALFRED_CONCURRENCY=2

ALFRED_SUBREACT_MAX_PAGES=10
ALFRED_SUBREACT_BROWSE_CONCURRENCY=3
ALFRED_SUBREACT_BATCH_SIZE=4
ALFRED_SUBREACT_LLM_MAX_CALLS=6
ALFRED_SUBREACT_MIN_CONFIDENCE=0.6

ALFRED_AGENT_MAX_DURATION_MS=600000
ALFRED_AGENT_MAX_TOOL_CALLS=18
ALFRED_AGENT_MAX_PARALLEL_TOOLS=3
ALFRED_AGENT_PLANNER_MAX_CALLS=10
ALFRED_AGENT_OBSERVATION_WINDOW=8
ALFRED_AGENT_DIMINISHING_THRESHOLD=2
