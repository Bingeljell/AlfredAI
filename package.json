{
  "name": "alfredv1",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:gateway": "tsx watch src/gateway/server.ts",
    "start": "tsx src/gateway/server.ts",
    "postinstall": "node scripts/setup-playwright.js",
    "setup:browsers": "playwright install chromium --with-deps",
    "test:unit": "node --import tsx --test tests/unit/**/*.test.ts",
    "test:integration": "node --import tsx --test tests/integration/**/*.test.ts",
    "test:smoke": "node --import tsx --test tests/smoke/**/*.test.ts",
    "test:security": "node --import tsx --test tests/security/**/*.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "cheerio": "^1.1.2",
    "dotenv": "^16.6.1",
    "hono": "^4.9.8",
    "playwright": "^1.55.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
