ALFRED_ENV=dev
PORT=3000

OPENAI_API_KEY=

SEARXNG_BASE_URL=http://127.0.0.1:8888
SEARXNG_SEARCH_PATH=/search
SEARXNG_HEALTH_PATH=/search?q=ping&format=json
SEARXNG_START_CMD=
SEARXNG_START_TIMEOUT_MS=15000
SEARXNG_RETRY_INTERVAL_MS=1000

BRAVE_SEARCH_API_KEY=

ALFRED_SEARCH_MAX_RESULTS=15
ALFRED_FAST_SCRAPE_COUNT=5
ALFRED_ENABLE_PLAYWRIGHT=true
ALFRED_RUN_MAX_STEPS=6
ALFRED_WORKSPACE_DIR=./workspace/alfred
ALFRED_CONCURRENCY=2
