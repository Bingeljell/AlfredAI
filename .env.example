ALFRED_ENV=dev
PORT=9001

# ── API auth ───────────────────────────────────────────────────────────────────
# Protects the web UI and all /v1/* API routes.
# If unset, Alfred auto-generates one on first startup and writes it here.
ALFRED_API_KEY=

# ── LLM providers — set at least one ──────────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Model selection (set to any model string your provider supports)
ALFRED_MODEL_SMART=gemini-2.0-flash        # main agent loop
ALFRED_MODEL_FAST=gemini-2.0-flash-lite    # fast/cheap calls

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=                 # comma-separated numeric user IDs

# ── Search ─────────────────────────────────────────────────────────────────────
SEARXNG_BASE_URL=http://127.0.0.1:8888
SEARXNG_SEARCH_PATH=/search
SEARXNG_HEALTH_PATH=/
SEARXNG_START_CMD=                         # leave blank if using Docker
SEARXNG_START_TIMEOUT_MS=15000
SEARXNG_RETRY_INTERVAL_MS=1000
SEARXNG_HEALTH_RETRIES=4
SEARXNG_HEALTH_RETRY_DELAY_MS=500
SEARXNG_HEALTH_GRACE_MS=60000

BRIGHTDATA_SEARCH_API_KEY=
BRIGHTDATA_SEARCH_BASE_URL=https://api.brightdata.com
BRIGHTDATA_SEARCH_PATH=/request
BRIGHTDATA_SEARCH_ZONE=
BRIGHTDATA_SEARCH_ENGINE=duckduckgo
BRIGHTDATA_SEARCH_COUNTRY=us
BRIGHTDATA_SEARCH_TIMEOUT_MS=12000

BRAVE_SEARCH_API_KEY=

# ── Pinchtab (real-browser scraping, optional) ─────────────────────────────────
ALFRED_ENABLE_PINCHTAB=false
PINCHTAB_BASE_URL=http://127.0.0.1:9867
PINCHTAB_START_CMD=                        # e.g. pinchtab

# ── Agent runtime ──────────────────────────────────────────────────────────────
ALFRED_WORKSPACE_DIR=./workspace/alfred
ALFRED_SEARCH_MAX_RESULTS=15
ALFRED_FAST_SCRAPE_COUNT=10
ALFRED_ENABLE_PLAYWRIGHT=true
ALFRED_CONCURRENCY=2
ALFRED_AGENT_MAX_DURATION_MS=600000
